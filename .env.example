# 微信服务号配置
WECHAT_TOKEN=your_wechat_token_here
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key_here

# 数据库配置
DATABASE_URL=sqlite:///./solo_auto_model.db

# SOLO Auto Model API 配置
MODEL_API_URL=http://localhost:8000/v1/chat/completions
MODEL_API_KEY=your_model_api_key_here
MODEL_TIMEOUT=30
MODEL_MAX_RETRIES=3
MODEL_RETRY_DELAY=1.0
MODEL_USE_MOCK=True

# 对话上下文配置
MAX_CONTEXT_LENGTH=20
MAX_TOKENS=4000
SYSTEM_PROMPT=你是一个乐于助人的AI助手。

# 领域功能配置
ENABLE_DOMAIN_DETECTION=True
DEFAULT_DOMAIN=general

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_SECRET_KEY=your-secret-key-change-in-production

# 图片生成功能配置
ENABLE_IMAGE_GENERATION=False
IMAGE_API_URL=https://api.example.com/v1/images/generations
IMAGE_API_KEY=your_image_api_key_here
IMAGE_USE_MOCK=True
